        "targetFrame": {"crs": "EPSG:3857"},
        "operation": {
          "type": "affine2d",
          "unit": "crs",
          "xoff": 0,
          "yoff": 0,
          "s11": 1,
          "s12": 2,
          "s21": 2,
          "s22": 4
        }
      }
    }
  ]
